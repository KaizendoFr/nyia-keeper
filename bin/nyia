#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later OR Proprietary

# Nyia Keeper Runtime Dispatcher
set -e

script_dir="$(dirname "$(realpath "$0")")"

# Source common functions
source "$script_dir/common-functions.sh" 2>/dev/null || {
    echo "Error: Could not load common functions library"
    exit 1
}

# Configuration
NYIAKEEPER_HOME=$(get_nyiakeeper_home)
CONFIG_DIR="$NYIAKEEPER_HOME/config"

# Source auto-update library (runtime only — best-effort)
_auto_update_lib="$script_dir/../lib/nyiakeeper/auto-update.sh"
[[ -f "$_auto_update_lib" ]] && source "$_auto_update_lib" 2>/dev/null || true

# Source update subcommands library (Plan 213)
_update_cmds_lib="$script_dir/../lib/nyiakeeper/update-commands.sh"
[[ -f "$_update_cmds_lib" ]] && source "$_update_cmds_lib" 2>/dev/null || true

# === DISPATCHER COMMANDS ===
list_available_assistants() {
    echo "Available Nyia Keeper Assistants:"
    echo ""
    
    local found_any=false
    
    # Check all potential assistants (both states)
    for config_file in "$CONFIG_DIR"/*.conf.example "$CONFIG_DIR"/*.conf; do
        if [[ -f "$config_file" ]]; then
            found_any=true
            
            # Determine state and display accordingly
            local base_name=""
            local status_icon=""
            local status_text=""
            
            if [[ "$config_file" == *.conf.example ]]; then
                base_name=$(basename "$config_file" .conf.example)
                # Skip if .conf version exists (configured takes precedence)
                [[ -f "$CONFIG_DIR/${base_name}.conf" ]] && continue
                
                status_icon="⚙️ "
                status_text="(needs configuration)"
            else
                base_name=$(basename "$config_file" .conf)
                status_icon="✅ "
                status_text="(ready)"
            fi
            
            printf "  %s%-12s %s\n" "$status_icon" "$base_name" "$status_text"
        fi
    done
    
    if [[ "$found_any" == "false" ]]; then
        echo "  No assistants found in: $CONFIG_DIR"
        echo ""
        echo "To get started:"
        echo "  1. Run installation: curl -fsSL https://github.com/KaizendoFr/nyia-keeper/releases/latest/download/install.sh | bash"
        echo "  2. Configure assistant: nyia-claude --help"
    fi
    
    echo ""
}

show_config_list() {
    local show_origin="${1:-false}"
    
    echo "Nyia Keeper Configuration:"
    
    if [[ "$show_origin" == "true" ]]; then
        # Show configuration with sources (Git pattern)
        if [[ -n "$NYIAKEEPER_HOME" ]]; then
            echo "  NYIAKEEPER_HOME=$NYIAKEEPER_HOME [environment]"
        else
            echo "  NYIAKEEPER_HOME=$NYIAKEEPER_HOME [platform default]"
        fi
        echo "  CONFIG_DIR=$CONFIG_DIR [derived]"
        echo "  DATA_DIR=$NYIAKEEPER_HOME/data [derived]"
    else
        # Show configuration values only
        echo "  NYIAKEEPER_HOME=$NYIAKEEPER_HOME"
        echo "  CONFIG_DIR=$CONFIG_DIR"
        echo "  DATA_DIR=$NYIAKEEPER_HOME/data"
    fi
    
    echo ""
    echo "Platform Information:"
    echo "  OS: $(uname -s)"
    echo "  Platform detected: $(uname -s)"
    
    if [[ -n "$XDG_CONFIG_HOME" ]]; then
        echo "  XDG_CONFIG_HOME=$XDG_CONFIG_HOME"
    fi
    
    echo ""
}

show_config_dump() {
    echo "# Nyia Keeper Configuration Dump"
    echo "# Generated on $(date)"
    echo ""
    
    echo "# Core Configuration"
    echo "NYIAKEEPER_HOME=$NYIAKEEPER_HOME"
    echo "CONFIG_DIR=$CONFIG_DIR"
    
    echo ""
    echo "# Platform Environment"
    echo "PLATFORM=$(uname -s)"
    echo "HOME=$HOME"
    [[ -n "$XDG_CONFIG_HOME" ]] && echo "XDG_CONFIG_HOME=$XDG_CONFIG_HOME"
    [[ -n "$APPDATA" ]] && echo "APPDATA=$APPDATA"
    
    echo ""
    echo "# Directory Structure"
    echo "DATA_DIR=$NYIAKEEPER_HOME/data"
    
    # Show if directories exist
    echo ""
    echo "# Directory Status"
    for dir in "$NYIAKEEPER_HOME" "$NYIAKEEPER_HOME/data" "$CONFIG_DIR"; do
        if [[ -d "$dir" ]]; then
            echo "EXISTS: $dir"
        else
            echo "MISSING: $dir"
        fi
    done
}

show_config_view() {
    echo "Nyia Keeper Effective Configuration:"
    echo ""
    echo "Home Directory: $NYIAKEEPER_HOME"
    echo "  Status: $(if [[ -d "$NYIAKEEPER_HOME" ]]; then echo "EXISTS"; else echo "MISSING"; fi)"
    echo ""
    
    echo "Available Assistants:"
    if [[ -d "$CONFIG_DIR" ]]; then
        for conf_file in "$CONFIG_DIR"/*.conf; do
            if [[ -f "$conf_file" ]]; then
                local assistant_name=$(basename "$conf_file" .conf)
                echo "  - $assistant_name ($(basename "$conf_file"))"
            fi
        done
    else
        echo "  Config directory not found: $CONFIG_DIR"
    fi
    
}

show_global_status() {
    echo "Nyia Keeper Global Status:"
    echo "  Home: $NYIAKEEPER_HOME"
    echo "  Config directory: $CONFIG_DIR"
    echo ""
    
    # Show system info
    echo "System Information:"
    echo "  Docker: $(command -v docker >/dev/null && echo "✅ Available" || echo "❌ Not found")"
    echo "  Git: $(command -v git >/dev/null && echo "✅ Available" || echo "❌ Not found")"
    echo ""
    
    list_available_assistants
    
    # Show data storage info
    echo "Data Storage:"
    local data_dir="$NYIAKEEPER_HOME/data"
    if [[ -d "$data_dir" ]]; then
        local project_count=$(find "$data_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | wc -l)
        echo "  Projects tracked: $project_count"
        echo "  Data directory: $data_dir"
    else
        echo "  No project data found"
    fi
    
    # Show global images
    echo ""
    echo "Docker Images:"
    if command -v docker >/dev/null; then
        # List both GHCR-pulled (dash-form) and locally-built (slash-form) images
        local found=false
        for pattern in "nyiakeeper-*" "nyiakeeper/*"; do
            if docker images --filter "reference=${pattern}" --format "table {{.Repository}}:{{.Tag}}\t{{.Size}}\t{{.CreatedAt}}" 2>/dev/null | tail -n +2 | grep -q .; then
                docker images --filter "reference=${pattern}" --format "  {{.Repository}}:{{.Tag}} ({{.Size}}, {{.CreatedAt}})" 2>/dev/null
                found=true
            fi
        done
        if [[ "$found" == "false" ]]; then
            echo "  No Nyia Keeper images found"
        fi
    else
        echo "  Docker not available"
    fi
}

clean_old_images() {
    echo "🧹 Cleaning old development images..."
    
    if ! command -v docker >/dev/null; then
        print_error "Docker not available for cleanup"
        exit 1
    fi
    
    # List images that would be cleaned
    echo ""
    echo "Images that will be removed:"
    # List both GHCR-pulled (dash-form) and locally-built (slash-form) dangling images
    for pattern in "nyiakeeper-*" "nyiakeeper/*"; do
        docker images --filter "reference=${pattern}" --filter "dangling=true" --format "  {{.Repository}}:{{.Tag}} ({{.Size}})" 2>/dev/null
    done
    # Show fallback if no dangling images found
    local dangling_count=0
    for pattern in "nyiakeeper-*" "nyiakeeper/*"; do
        dangling_count=$((dangling_count + $(docker images --filter "reference=${pattern}" --filter "dangling=true" --format "1" 2>/dev/null | wc -l)))
    done
    if [[ "$dangling_count" -eq 0 ]]; then
        echo "  No dangling images found"
    fi
    
    # Ask for confirmation
    echo ""
    echo "⚠️  This will remove dangling Nyia Keeper images to free up space."
    echo "   Active images will NOT be removed."
    echo ""
    read -p "Continue? [y/N] " -n 1 -r
    echo
    
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        echo "Removing dangling images..."
        if docker image prune --filter "label=nyiakeeper=true" --force 2>/dev/null; then
            echo "✅ Cleanup completed"
        else
            echo "✅ No images to clean"
        fi
    else
        echo "Cleanup cancelled"
    fi
}

# Startup update check (skip for utility commands)
case "${1:-}" in
    update|rollback|help|--help|-h|config|"") ;;
    *) type check_for_updates_if_due &>/dev/null && check_for_updates_if_due || true ;;
esac

# Runtime dispatcher with full functionality
case "${1:-help}" in
    config)
        # Handle configuration commands
        if [[ -z "${2:-}" ]]; then
            echo "Usage: nyia config <command>"
            echo ""
            echo "Commands:"
            echo "  list [--show-origin]  Show configuration values"
            echo "  dump                  Show all configuration with environment"
            echo "  view                  Show effective configuration"
            echo "  get <key>            Get specific configuration value"
            echo ""
            echo "Available keys for 'get':"
            echo "  home, NYIAKEEPER_HOME    Home directory path"
            echo "  config, CONFIG_DIR         Config directory path"
            echo "  data, DATA_DIR             Data directory path"
            echo ""
            echo "Examples:"
            echo "  nyia config list --show-origin"
            echo "  nyia config get home"
            exit 0
        fi
        
        local subcommand="$2"
        case "$subcommand" in
            list)
                local show_origin="false"
                if [[ "${3:-}" == "--show-origin" ]]; then
                    show_origin="true"
                fi
                show_config_list "$show_origin"
                ;;
            dump)
                show_config_dump
                ;;
            view)
                show_config_view
                ;;
            get)
                local key="${3:-}"
                case "$key" in
                    NYIAKEEPER_HOME|home) echo "$NYIAKEEPER_HOME" ;;
                    CONFIG_DIR|config) echo "$CONFIG_DIR" ;;
                    DATA_DIR|data) echo "$NYIAKEEPER_HOME/data" ;;
                    *) echo "Unknown config key: $key" >&2; exit 1 ;;
                esac
                ;;
            *)
                echo "Unknown config command: $subcommand" >&2
                echo "Use 'nyia config' for usage information"
                exit 1
                ;;
        esac
        ;;
    list)
        list_available_assistants
        ;;
    status)
        show_global_status
        ;;
    clean)
        clean_old_images
        ;;
    update)
        shift
        if type handle_update_command &>/dev/null; then
            handle_update_command "$@"
        else
            echo "Error: Update commands library not available." >&2
            exit 1
        fi
        ;;
    rollback)
        shift
        if type handle_update_command &>/dev/null; then
            handle_update_command "rollback" "$@"
        else
            echo "Error: Update commands library not available." >&2
            exit 1
        fi
        ;;
    exclusions)
        # Handle exclusions command
        shift
        script_dir_real="$(dirname "$(realpath "$0")")"
        exclusions_lib="$script_dir_real/../lib/exclusions-commands.sh"
        mount_exclusions_lib="$script_dir_real/../lib/mount-exclusions.sh"
        
        # Source the exclusions commands library
        if [[ -f "$exclusions_lib" ]]; then
            source "$exclusions_lib"
        else
            echo "Error: Exclusions commands library not found"
            echo "Missing: $exclusions_lib"
            exit 1
        fi
        
        # Source the mount exclusions library
        if [[ -f "$mount_exclusions_lib" ]]; then
            source "$mount_exclusions_lib"
        else
            echo "Error: Mount exclusions library not found"
            echo "Missing: $mount_exclusions_lib"
            exit 1
        fi
        
        handle_exclusions_command "$@"
        ;;
    completions)
        # Output shell completion script to stdout
        shift
        _script_base="$(dirname "$(realpath "$0")")"
        if [[ -d "$_script_base/../lib/completions" ]]; then
            completions_dir="$_script_base/../lib/completions"
        else
            completions_dir="$_script_base/../lib/nyiakeeper/completions"
        fi
        shell_arg="${1:-}"
        case "$shell_arg" in
            bash)
                if [[ -f "$completions_dir/nyia.bash" ]]; then
                    cat "$completions_dir/nyia.bash"
                    if [ -t 2 ]; then
                        echo "" >&2
                        echo "# To enable permanently, add to your ~/.bashrc:" >&2
                        echo "#   eval \"\$(nyia completions bash)\"" >&2
                    fi
                else
                    echo "Error: Bash completion script not found" >&2
                    exit 1
                fi
                ;;
            zsh)
                if [[ -f "$completions_dir/nyia.zsh" ]]; then
                    cat "$completions_dir/nyia.zsh"
                    if [ -t 2 ]; then
                        echo "" >&2
                        echo "# To enable permanently, add to your ~/.zshrc:" >&2
                        echo "#   eval \"\$(nyia completions zsh)\"" >&2
                    fi
                else
                    echo "Error: Zsh completion script not found" >&2
                    exit 1
                fi
                ;;
            *)
                echo "Usage: nyia completions <shell>"
                echo ""
                echo "Available shells:"
                echo "  bash    Generate Bash completion script"
                echo "  zsh     Generate Zsh completion script"
                echo ""
                echo "To enable auto-completion:"
                echo "  Bash: eval \"\$(nyia completions bash)\""
                echo "  Zsh:  eval \"\$(nyia completions zsh)\""
                ;;
        esac
        ;;
    help|--help|-h)
        echo "Nyia Keeper Multi-Assistant Infrastructure"
        echo "AI-powered development assistants for your projects"
        echo ""
        echo "QUICK START:"
        echo "  1. Configure an assistant: nyia-codex --help"
        echo "  2. Start using: nyia-codex"
        echo ""
        echo "COMMANDS:"
        echo "  nyia list                   # List available assistants"
        echo "  nyia status                 # Show system status and information"
        echo "  nyia config <command>       # Configure system settings"
        echo "  nyia clean                  # Clean old Docker images"
        echo "  nyia exclusions [command]   # Manage file exclusions"
        echo "  nyia update <subcommand>    # Update management"
        echo "  nyia rollback               # Rollback to previous version"
        echo "  nyia completions <shell>    # Generate shell auto-completion (bash, zsh)"
        echo "  nyia help                   # Show this help"
        echo ""
        echo "UPDATE MANAGEMENT:"
        echo "  nyia update status          # Show version, channel, last check"
        echo "  nyia update list            # Show channels and recent releases"
        echo "  nyia update check           # Check for updates"
        echo "  nyia update install [target] # Install update (channel or version)"
        echo "  nyia update rollback        # Rollback to previous version"
        echo "  nyia update [version]       # Install specific version (shortcut)"
        echo "  nyia update --list          # List versions (backward compat)"
        echo ""
        echo "ASSISTANTS:"
        echo "  nyia-claude [options]       # Anthropic Claude (advanced reasoning)"
        echo "  nyia-gemini [options]       # Google Gemini (multimodal)"
        echo "  nyia-codex [options]        # OpenAI Codex (code generation)"
        echo "  nyia-opencode [options]     # Open-source models (local/custom)"
        echo ""
        echo "CONFIGURATION:"
        echo "  nyia config list [--show-origin]     # Show configuration values"
        echo "  nyia config dump                     # Show all configuration"
        echo "  nyia config view                     # Show effective configuration"
        echo "  nyia config get <key>                # Get specific value"
        echo ""
        echo "EXCLUSIONS (Security):"
        echo "  nyia exclusions lockdown    # Scan project, generate exclude-everything config"
        echo "  nyia exclusions list        # Show excluded files/patterns"
        echo "  nyia exclusions status      # Check exclusion system status"
        echo ""
        echo "EXAMPLES:"
        echo "  nyia list                             # See what's available"
        echo "  nyia status                           # Check system status"
        echo "  nyia config list                      # Show current configuration"
        echo "  nyia config get home                  # Get home directory path"
        echo "  nyia clean                            # Clean up old Docker images"
        echo "  nyia-claude --login                   # Configure Claude"
        echo "  nyia-claude                            # Start Claude session"
        echo ""
        echo "TROUBLESHOOTING:"
        echo "  - Config not found? Check ~/.config/nyiakeeper/config/"
        echo "  - Docker issues? Ensure Docker is running and you have access"
        echo "  - Need help? Visit: https://github.com/KaizendoFr/nyia-keeper"
        echo ""
        echo "For assistant-specific help: nyia-<assistant> --help"
        ;;
    *)
        echo "Unknown command: $1"
        echo "Use 'nyia help' for usage information"
        exit 1
        ;;
esac
